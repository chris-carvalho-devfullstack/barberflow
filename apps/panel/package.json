{
  "name": "panel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && (cp -r .next/standalone/apps/panel/. .next/standalone/ || true)",
    "start": "next start",
    "lint": "eslint",
    "worker:build": "npx @opennextjs/cloudflare build && mkdir -p .open-next/assets/_worker.js && cp -rL .open-next/worker.js .open-next/server-functions .open-next/cloudflare .open-next/.build .open-next/assets/_worker.js/ && (cp -rL .open-next/middleware .open-next/assets/_worker.js/ 2>/dev/null || true) && mv .open-next/assets/_worker.js/worker.js .open-next/assets/_worker.js/index.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/auth-helpers-react": "^0.15.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "3.8.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
